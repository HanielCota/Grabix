{
  "name": "grabix",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@11.0.0",
  "engines": {
    "node": ">=22.6.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/ e2e/ tests/ drizzle.config.ts next.config.ts playwright.config.ts postcss.config.mjs",
    "lint:fix": "biome check --write src/ e2e/ tests/ drizzle.config.ts next.config.ts playwright.config.ts postcss.config.mjs",
    "format": "biome format --write src/ e2e/ tests/ drizzle.config.ts next.config.ts playwright.config.ts postcss.config.mjs",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "test": "npm run test:unit && npm run test:e2e",
    "test:e2e": "playwright test",
    "test:unit": "tsx --test \"tests/unit/**/*.test.ts\""
  },
  "dependencies": {
    "@auth/drizzle-adapter": "^1.11.2",
    "@upstash/redis": "^1.38.0",
    "archiver": "^8.0.0",
    "cheerio": "^1.2.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.24.0",
    "motion": "^12.42.2",
    "next": "^16.2.10",
    "next-auth": "^5.0.0-beta.31",
    "postgres": "^3.4.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.2",
    "undici": "^8.7.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@biomejs/biome": "2.5.2",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/archiver": "^8.0.0",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "^0.31.10",
    "postcss": "^8.5.10",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "esbuild": "^0.25.0",
    "postcss": "^8.5.10"
  }
}
