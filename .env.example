# ─── Grabix Configuration ───
# All values below are optional — defaults are used when not set.

# User agent for HTTP requests
# GRABIX_USER_AGENT="Mozilla/5.0 (compatible; Grabix/1.0; +https://github.com/HanielCota/grabix)"

# Enable JavaScript rendering via Playwright (requires: npm install playwright)
# GRABIX_JS_RENDERING=false

# ─── Limits ───
# GRABIX_FETCH_TIMEOUT_MS=15000
# GRABIX_MAX_HTML_SIZE_BYTES=10485760
# GRABIX_MAX_ASSETS=200
# GRABIX_MAX_FILE_SIZE_BYTES=104857600
# GRABIX_MAX_ZIP_SIZE_BYTES=524288000
# GRABIX_MAX_CONCURRENT_DOWNLOADS=5

# ─── Crawl ───
# GRABIX_CRAWL_MAX_PAGES=30
# GRABIX_CRAWL_MAX_DEPTH=2
# GRABIX_CRAWL_CONCURRENCY=5
# GRABIX_CRAWL_SAME_DOMAIN_ONLY=true

# ════════════════════════════════════════════════════════════════
#  Plans / Auth / Billing  (REQUIRED for the freemium model)
# ════════════════════════════════════════════════════════════════

# ─── Database (Postgres) ───
# Any Postgres works (Neon, Supabase, Railway, local). Run migrations after setting:
#   npx drizzle-kit migrate
DATABASE_URL="postgres://user:password@host:5432/grabix"

# ─── Auth.js (NextAuth v5) ───
# Generate a secret:  npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET=""
# In production set the canonical URL (not needed on Vercel):
# AUTH_URL="https://grabix.app"

# Google OAuth — create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: https://YOUR_DOMAIN/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# ─── Mercado Pago (billing) ───
# Access token (server): MP dashboard → Your integrations → app → Credentials.
# Use TEST credentials in dev, PRODUCTION in prod.
MP_ACCESS_TOKEN=""
# Webhook secret for x-signature validation: MP → Webhooks → "Secret key".
MP_WEBHOOK_SECRET=""
# Monthly Pro amount in BRL (the real charge). Display label is separate below.
MP_PRO_AMOUNT="19.90"

# Webhook URL to register in Mercado Pago: https://YOUR_DOMAIN/api/webhooks/mercadopago
# Subscribe topics: "subscription_preapproval" and "subscription_authorized_payment".

# Price label shown in the UI (display only).
NEXT_PUBLIC_PRO_PRICE_LABEL="R$ 19,90/mês"
